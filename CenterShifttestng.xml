<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Center Shift - Critical Tests" verbose="1">

    <parameter name="browser" value="chrome"/>

    <!--
        11 Center Shift tests — run in priority order (1 → 11)

        PRE-CONDITIONS (set constants in ServiceRequest_CenterShiftTest.java):
          CS_CHILD_ID        — Active Regular child; no pending CS; no unpaid invoice;
                               last approved CS >= 60 days ago (or first CS ever)
          CS_NEW_CENTER      — Valid "Shift To" center for CS_CHILD_ID (Sector 122, Noida)
          CS_CORPORATE_NO    — Corporate tie-up child with flag=NO  (blocked)
          CS_COOLDOWN_CHILD  — Child whose last approved CS was < 60 days ago  (TODO)
          CS_UNPAID_CHILD    — Child with at least one unpaid invoice  (TODO)
          CS_CANCEL_CHILD    — Child for cancel/cleanup test
          CS_CORPORATE_YES   — Corporate tie-up child with flag=YES (optional, TODO)

        FLOW:
          tc001 → submit CS → Pending
          tc002 → try duplicate → blocked
          tc003 → Cron: Pending → Processing  (RestAssured)
          tc004 → Cron: Processing → Approved  (RestAssured, Joining Date must be within ±5 days)
          tc005 → Cron: Old child Attrition    (RestAssured)
          tc006 → Corporate flag=NO child → blocked
          tc007 → Joining Date today+1 → server rejects
          tc008 → 60-day cooldown → blocked  (skips if TODO)
          tc009 → Unpaid invoice → blocked    (skips if TODO)
          tc010 → Cancel pending CS (cleanup)
          tc011 → Corporate flag=YES → CS accessible (optional, skips if TODO)
    -->

    <test name="Center Shift - All Critical Tests">
        <classes>
            <class name="testScripts.SupportTests.ServiceRequest_CenterShiftTest">
                <methods>
                    <include name="tc001_submitCenterShift"/>
                    <include name="tc002_duplicateBlocked"/>
                    <include name="tc003_pendingToProcessing"/>
                    <include name="tc004_processingToApproved"/>
                    <include name="tc005_oldChildAttrition"/>
                    <include name="tc006_corporateBlocked"/>
                    <include name="tc007_minDateBlocked"/>
                    <include name="tc008_cooldownBlocked"/>
                    <include name="tc009_unpaidInvoiceBlocked"/>
                    <include name="tc010_cancelPending"/>
                    <include name="tc011_corporateYesAllowed"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>
