<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Due Invoices Payment Suite" verbose="1">

    <parameter name="browser" value="chrome"/>

    <!--
    ══════════════════════════════════════════════════════════════
     TC_001  extractUpiPaymentJson      Extract UPI JSON + POST API + mark Paid
     TC_002  completeCardPaymentFlow    Full ICICI gateway browser payment
     TC_003  captureUpiJsonForJmeter    Extract UPI JSON → save JMeter CSV only
     TC_004  captureCcdcJsonForJmeter   Extract CC/DC JSON → save JMeter CSV only
     TC_005  extractCcdcJsonAndPostApi  Extract CC/DC JSON + POST API + mark Paid
    ══════════════════════════════════════════════════════════════
    -->

    <!-- ════ RUN ALL — TC_001 through TC_005 in order ════ -->
    <test name="Due Invoices - All Tests">
        <classes>
            <class name="testScripts.SupportTests.DueInvoices_Testcases">
                <methods>
                    <include name="extractUpiPaymentJson"/>
                    <include name="completeCardPaymentFlow"/>
                    <include name="captureUpiJsonForJmeter"/>
                    <include name="captureCcdcJsonForJmeter"/>
                    <include name="extractCcdcJsonAndPostApi"/>
                </methods>
            </class>
        </classes>
    </test>

    <!-- ════ INDIVIDUAL RUNS ════ -->

    <!-- TC_001 -->
    <test name="TC_001 - Process UPI Payment">
        <classes>
            <class name="testScripts.SupportTests.DueInvoices_Testcases">
                <methods>
                    <include name="extractUpiPaymentJson"/>
                </methods>
            </class>
        </classes>
    </test>

    <!-- TC_002 -->
    <test name="TC_002 - Process Card Payment via Gateway">
        <classes>
            <class name="testScripts.SupportTests.DueInvoices_Testcases">
                <methods>
                    <include name="completeCardPaymentFlow"/>
                </methods>
            </class>
        </classes>
    </test>

    <!-- TC_003 -->
    <test name="TC_003 - Capture UPI JSON for JMeter">
        <classes>
            <class name="testScripts.SupportTests.DueInvoices_Testcases">
                <methods>
                    <include name="captureUpiJsonForJmeter"/>
                </methods>
            </class>
        </classes>
    </test>

    <!-- TC_004 -->
    <test name="TC_004 - Capture Card JSON for JMeter">
        <classes>
            <class name="testScripts.SupportTests.DueInvoices_Testcases">
                <methods>
                    <include name="captureCcdcJsonForJmeter"/>
                </methods>
            </class>

        </classes>
    </test>

    <!-- TC_005 -->
    <test name="TC_005 - Process Card JSON via API">
        <classes>
            <class name="testScripts.SupportTests.DueInvoices_Testcases">
                <methods>
                    <include name="extractCcdcJsonAndPostApi"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>
